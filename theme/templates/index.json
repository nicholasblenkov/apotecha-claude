    "brand_story": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<div class=\"apotecha-story\"><div class=\"apotecha-story__text\"><h2 class=\"apotecha-story__heading\">Clean Haircare,<br>Without Compromise</h2><p class=\"apotecha-story__body\">We believe healthy hair shouldn't come at the cost of the planet. Every Apotecha bar is handcrafted with hydrolysed rice protein and botanical extracts — zero water, zero plastic, zero sulfates. Just clean, concentrated care that works.</p><a href=\"/pages/about\" class=\"apotecha-story__cta\">Read More</a></div><div class=\"apotecha-story__image-wrap\"><img src=\"https://cdn.shopify.com/s/files/1/1008/2261/4403/files/Apotecha_oily_background.jpg?v=1776094979\" alt=\"Apotecha Shampoo Bar\" class=\"apotecha-story__hero-img\" loading=\"lazy\" width=\"600\" height=\"900\"></div></div>",
