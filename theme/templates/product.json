    "comparison": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<div class=\"apotecha-comparison\"><div class=\"apotecha-comparison__left\"><h2>Why Apotecha<br>is the <em>perfect choice</em></h2></div><div class=\"apotecha-comparison__table\"><ul class=\"apotecha-comparison__features\"><li>Hydrolysed rice protein</li><li>Replaces up to 3 bottles</li><li>Zero water formula</li><li>Natural botanical extracts</li><li>Made with natural fragrance</li><li>Vegan &amp; cruelty free</li><li>Zero sulfates, silicones &amp; parabens</li></ul><div class=\"apotecha-comparison__col apotecha-comparison__col--us\"><p class=\"apotecha-comparison__col-title\">Apotecha</p><span class=\"apotecha-check\">✓</span><span class=\"apotecha-check\">✓</span><span class=\"apotecha-check\">✓</span><span class=\"apotecha-check\">✓</span><span class=\"apotecha-check\">✓</span><span class=\"apotecha-check\">✓</span><span class=\"apotecha-check\">✓</span></div><div class=\"apotecha-comparison__col apotecha-comparison__col--others\"><p class=\"apotecha-comparison__col-title\">Others</p><span class=\"apotecha-x\">✗</span><span class=\"apotecha-x\">✗</span><span class=\"apotecha-x\">✗</span><span class=\"apotecha-x\">✗</span><span class=\"apotecha-x\">✗</span><span class=\"apotecha-check\">✓</span><span class=\"apotecha-x\">✗</span></div></div></div>",
