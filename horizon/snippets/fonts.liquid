{% # theme-check-disable %}

{% comment %} Apotecha: Preload custom Futura font files {% endcomment %}
<link rel="preload" as="font" href="{{ 'futura-medium.woff2' | asset_url }}" type="font/woff2" crossorigin fetchpriority="high">
<link rel="preload" as="font" href="{{ 'futura-bold.woff2' | asset_url }}" type="font/woff2" crossorigin fetchpriority="high">
<link rel="preload" as="font" href="{{ 'futura-medium-italic.woff2' | asset_url }}" type="font/woff2" crossorigin fetchpriority="low">
<link rel="preload" as="font" href="{{ 'futura-condensed-medium.woff2' | asset_url }}" type="font/woff2" crossorigin fetchpriority="low">
<link rel="preload" as="font" href="{{ 'futura-condensed-extrabold.woff2' | asset_url }}" type="font/woff2" crossorigin fetchpriority="low">

{%- unless settings.type_body_font.system? -%}
  <link
    rel="preload"
    as="font"
    href="{{ settings.type_body_font | font_url }}"
    type="font/woff2"
    crossorigin
    fetchpriority="low"
  >
{%- endunless -%}
{%- unless settings.type_subheading_font.system? -%}
  <link
    rel="preload"
    as="font"
    href="{{ settings.type_subheading_font | font_url }}"
    type="font/woff2"
    crossorigin
    fetchpriority="low"
  >
{%- endunless -%}
{%- unless settings.type_heading_font.system? -%}
  <link
    rel="preload"
    as="font"
    href="{{ settings.type_heading_font | font_url }}"
    type="font/woff2"
    crossorigin
    fetchpriority="low"
  >
{%- endunless -%}
{%- unless settings.type_accent_font.system? -%}
  <link
    rel="preload"
    as="font"
    href="{{ settings.type_accent_font | font_url }}"
    type="font/woff2"
    crossorigin
    fetchpriority="low"
  >
{%- endunless -%}
{% # theme-check-enable %}
